datasource db {
  provider = "sqlite"
}

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

model Admin {
  id           String   @id @default(uuid())
  username     String   @unique
  passwordHash String
  name         String
  email        String   @unique
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Teacher {
  id              String           @id @default(uuid())
  employeeId      String           @unique
  passwordHash    String
  name            String
  email           String           @unique
  phone           String
  photoUrl        String
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  students        Student[]
  attendance      Attendance[]
  attendanceSlots AttendanceSlot[]
  announcements   Announcement[]
  marks           Mark[]
}

model Student {
  id           String   @id @default(uuid())
  rollNumber   String
  passwordHash String
  name         String
  email        String   @unique
  phone        String
  class        String
  section      String
  photoUrl     String
  teacherId    String?
  teacher      Teacher? @relation(fields: [teacherId], references: [id], onDelete: SetNull)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  attendance   Attendance[]
  marks        Mark[]

  @@index([teacherId])
}

model Attendance {
  id                String          @id @default(uuid())
  studentId         String
  student           Student         @relation(fields: [studentId], references: [id], onDelete: Cascade)
  date              String          // YYYY-MM-DD
  status            String          // "present" | "absent" | "late" | "leave" | "medical"
  markedByTeacherId String
  markedByTeacher   Teacher         @relation(fields: [markedByTeacherId], references: [id], onDelete: Cascade)
  slotId            String?
  slot              AttendanceSlot? @relation(fields: [slotId], references: [id], onDelete: Cascade)
  isArchived        Boolean         @default(false)
  deletedAt         DateTime?
  deletedBy         String?
  latitude          String?
  longitude         String?
  device            String?
  scannerId         String?
  remarks           String?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  @@unique([studentId, date, slotId]) // Unique student, date, and slot
  @@index([markedByTeacherId])
  @@index([slotId])
  @@index([studentId])
  @@index([date])
  @@index([isArchived])
}

model AttendanceSlot {
  id          String       @id @default(uuid())
  createdBy   String       // Teacher's name or ID
  teacherId   String
  teacher     Teacher      @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  classId     String       // e.g. "1" (corresponding to class on Student)
  sectionId   String       // e.g. "B" (corresponding to section on Student)
  date        String       // YYYY-MM-DD
  time        String       // e.g. "09:00 AM"
  duration    Int          @default(30) // duration in minutes
  type        String       // e.g. Morning, Afternoon, Evening, Extra Class, Practical, etc.
  status      String       @default("active") // "active" | "completed" | "SAVED" | "LOCKED"
  isArchived  Boolean      @default(false)
  deletedAt   DateTime?
  deletedBy   String?
  isLocked    Boolean      @default(false)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  attendances Attendance[]

  @@unique([teacherId, classId, sectionId, date, time])
  @@index([teacherId])
  @@index([date])
  @@index([isArchived])
}

model Announcement {
  id            String    @id @default(uuid())
  title         String
  content       String    // description
  category      String    // e.g. "PTM", "Holiday", "Event", "General"
  dateInfo      String    // e.g. "July 20, 2026"
  priority      String    @default("Normal") // "Normal" | "High" | "Low"
  status        String    @default("published") // "draft" | "published" | "scheduled"
  publishDate   String?   // YYYY-MM-DD
  expiryDate    String?   // YYYY-MM-DD
  audienceType  String    @default("All Students") // "All Students" | "Specific Class" | "Specific Section" | "Specific Students"
  classId       String?
  sectionId     String?
  studentIds    String?   // comma-separated list
  attachmentUrl String?
  thumbnail     String?
  isDeleted     Boolean   @default(false)
  deletedAt     DateTime?
  teacherId     String?   // links to Teacher who created it
  teacher       Teacher?  @relation(fields: [teacherId], references: [id], onDelete: SetNull)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @default(now()) @updatedAt
}

model Mark {
  id               String   @id @default(uuid())
  studentId        String
  student          Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  subject          String
  examName         String
  marksObtained    Float    @default(0)
  maxMarks         Float    @default(100)
  attendanceStatus String   @default("present")
  remarks          String?
  teacherId        String
  teacher          Teacher  @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([studentId, subject, examName])
  @@index([studentId])
  @@index([teacherId])
}

model AttendanceAudit {
  id             String   @id @default(uuid())
  attendanceId   String?
  slotId         String?
  action         String   @default("Created") // "Created" | "Updated" | "Soft-Deleted" | "Restored" | "Locked" | "Unlocked" | "Exported" | "Viewed"
  performedBy    String?
  role           String?
  teacherId      String
  classId        String
  sectionId      String
  slotType       String
  attendanceDate String
  serverTime     String
  oldValue       String?
  newValue       String?
  createdAt      DateTime @default(now())
  savedAt        DateTime @default(now())
  ipAddress      String?
  deviceId       String?

  @@index([slotId])
  @@index([performedBy])
  @@index([attendanceDate])
}



